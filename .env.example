# Konflux Lightspeed — Local Development Environment
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LLM Provider: Google Gemini API (default) ---
# Get your API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# --- Alternative: Google Vertex AI ---
# Requires a GCP service account with roles/aiplatform.user
# Uncomment and update local/config/run.yaml to use the Vertex AI provider block.
# VERTEXAI_PROJECT_ID=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1
# GCP_CREDENTIALS_PATH=/path/to/your/google-credentials.json
# GOOGLE_APPLICATION_CREDENTIALS=/etc/gcp/credentials.json

# --- Alternative: OpenAI ---
# Uncomment and update local/config/run.yaml to use the OpenAI provider block.
# OPENAI_API_KEY=sk-your-key-here

# --- PostgreSQL (defaults match podman-compose) ---
POSTGRES_USER=lightspeed
POSTGRES_PASSWORD=lightspeed
POSTGRES_DB=lightspeed
